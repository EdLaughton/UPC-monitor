<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>UPC Decisions Mirror</title>
  <style>
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      margin: 0;
      color: #172033;
      background: #f7f8fa;
    }
    header {
      padding: 24px;
      background: #ffffff;
      border-bottom: 1px solid #d9dee7;
    }
    main {
      padding: 24px;
      overflow-x: auto;
    }
    h1 {
      margin: 0 0 8px;
      font-size: 24px;
      font-weight: 650;
    }
    p {
      margin: 0;
      color: #526072;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: #ffffff;
      font-size: 14px;
    }
    th, td {
      border-bottom: 1px solid #d9dee7;
      padding: 10px 12px;
      text-align: left;
      vertical-align: top;
    }
    th {
      position: sticky;
      top: 0;
      background: #eef2f6;
      color: #243248;
      font-weight: 650;
      white-space: nowrap;
    }
    td.parties,
    td.preview {
      min-width: 220px;
      max-width: 420px;
    }
    td.refs {
      white-space: nowrap;
    }
    a {
      color: #0c5aa6;
    }
    .empty {
      padding: 32px 24px;
      background: #ffffff;
      border: 1px solid #d9dee7;
    }
  </style>
</head>
<body>
  <header>
    <h1>UPC Decisions Mirror</h1>
    <p>Generated {{ generated_at }}. Newest decisions are listed first. JSON feed: <a href="/latest.json">/latest.json</a>.</p>
  </header>
  <main>
    {% if decisions %}
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Document</th>
          <th>References</th>
          <th>Division</th>
          <th>Parties</th>
          <th>Headnote Preview</th>
          <th>Keyword Preview</th>
          <th>Links</th>
        </tr>
      </thead>
      <tbody>
        {% for item in decisions %}
        <tr>
          <td>{{ item.decision_date }}</td>
          <td>{{ item.document_type or item.title_raw }}<br>{{ item.type_of_action }}</td>
          <td class="refs">
            {% if item.case_number %}{{ item.case_number }}<br>{% endif %}
            {% if item.registry_number %}{{ item.registry_number }}<br>{% endif %}
            {{ item.order_or_decision_number }}
          </td>
          <td>{{ item.division }}</td>
          <td class="parties">{{ item.parties_raw | replace("\n", "<br>") | safe }}</td>
          <td class="preview">{{ item.headnote_text | preview }}</td>
          <td class="preview">{{ item.keywords_raw | preview }}</td>
          <td>
            {% if item.pdf_url_mirror %}<a href="{{ item.pdf_url_mirror }}">Mirror PDF</a><br>{% endif %}
            {% if item.node_url %}<a href="{{ item.node_url }}">Official detail</a><br>{% endif %}
            {% if item.pdf_url_official %}<a href="{{ item.pdf_url_official }}">Official PDF</a>{% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <div class="empty">No decisions have been ingested yet.</div>
    {% endif %}
  </main>
</body>
</html>
